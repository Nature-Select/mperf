# Node
node_modules/
.pnpm-store/
.pnpm-debug.log*
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Rust / Cargo
target/
**/*.rs.bk
Cargo.lock.bak

# Tauri build output
apps/desktop/src-tauri/target/
apps/desktop/src-tauri/gen/

# Vite / build
dist/
dist-ssr/
.vite/

