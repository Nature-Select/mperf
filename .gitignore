*.swo
.DS_Store

# Env
.env
.env.local
.env.*.local

# Logs
*.log
logs/

# Binaries directory: contents are large platform-specific blobs;
# tracked via a manifest, not committed directly
binaries/*/
!binaries/.gitkeep
!binaries/README.md

# Tauri sidecar binaries (fetched via `pnpm fetch:adb`)
apps/desktop/src-tauri/binaries/adb-*
apps/desktop/src-tauri/binaries/*.dll
apps/desktop/src-tauri/binaries/*.exe
design/icon-candidates/
